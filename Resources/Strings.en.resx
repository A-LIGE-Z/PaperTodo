  <data name="TipShowLinkedNoteName" xml:space="preserve">
    <value>Show the linked note title after the todo item.</value>
  </data>
  <data name="TipAllowLongLinkedNoteTitles" xml:space="preserve">
    <value>When off, linked note titles stay compact. When on, they expand to fit content: about 5 full-width characters on one-line todos and 10 on multiline todos.</value>
